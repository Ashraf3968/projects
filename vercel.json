{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix electronics-shop/client",
  "buildCommand": "npm run build --prefix electronics-shop/client",
  "outputDirectory": "electronics-shop/client/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
